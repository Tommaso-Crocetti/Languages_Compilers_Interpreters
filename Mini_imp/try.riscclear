main:
	copy in => r0
	LoadI 0 => ra
	less r0 ra => ra
	CJump ra l1 l2
l1:
	LoadI 0 => ra
	sub ra r0 => r0
	Jump l2
l2:
	LoadI 1 => ra
	less r0 ra => ra
	CJump ra l3 l4
l3:
	LoadI 0 => r0
	Jump l4
l4:
	addI r0 1 => r1
	Jump l5
l5:
	less r0 r1 => rb
	less r1 r0 => r2
	or ra r2 => ra
	CJump ra l6 l9
l6:
	less r0 r1 => ra
	CJump ra l7 l8
l7:
	sub r1 r0 => r1
	Jump l5
l8:
	sub r0 r1 => r0
	Jump l5
l9:
	copy r0 => out
