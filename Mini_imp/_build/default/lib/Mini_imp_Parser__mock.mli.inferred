type token =
    WHILE
  | VAR of string
  | TRUE
  | TIMES
  | THEN
  | SKIP
  | RPAREN
  | PROGRAM of (string * string)
  | PLUS
  | OR
  | OF_BOOL
  | NOT
  | MINUS
  | MINOR
  | LPAREN
  | INT of int
  | IF
  | FALSE
  | EOF
  | ELSE
  | DO
  | CONCAT
  | ASSIGN
  | AND
val menhir_begin_marker : int
val xv_prg : Mini_imp.program
val xv_cmd : Mini_imp.command
val xv_b_exp : Mini_imp.b_exp
val xv_a_exp : Mini_imp.a_exp
val menhir_end_marker : int
